# ─────────────────────────────────────────────────────────────────────────
# Flywheel.dev — variáveis de ambiente
# Copie para `.env.local` (não versionado) e preencha. Em produção, defina
# as mesmas no painel da Vercel (Project → Settings → Environment Variables).
# Variáveis NEXT_PUBLIC_* são expostas no browser; as demais são server-only.
# ─────────────────────────────────────────────────────────────────────────

# ── E-mail (Resend) ────────────────────────────────────────────────────────
# Chave da API do Resend. SEM ela, em dev o handler loga o payload e simula
# sucesso; em produção os formulários retornam 503.
RESEND_API_KEY=
# Remetente. Precisa ser um domínio verificado no Resend (ex.: "Flywheel.dev
# <contacto@flywheel.dev>"). Para testes, use onboarding@resend.dev.
RESEND_FROM="Flywheel.dev <onboarding@resend.dev>"
# Caixa que recebe os leads/candidaturas (server-only).
CONTACT_EMAIL=josevictorsilvafranca@gmail.com

# ── Domínio / SEO ──────────────────────────────────────────────────────────
# URL canônica do site (afeta sitemap, OpenGraph, canonical, metadataBase).
# Sem barra final. Ex.: https://flywheel.dev
NEXT_PUBLIC_SITE_URL=https://flywheel.dev

# ── Contato direto (exposto no client) ─────────────────────────────────────
# Número do WhatsApp em formato internacional, só dígitos (DDI+DDD+número).
NEXT_PUBLIC_WHATSAPP_NUMBER=5511999999999
# Link do Calendly (ou outra agenda) para agendar a call.
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/flywheel-dev/diagnostico
# E-mail exibido no site (pode diferir do CONTACT_EMAIL que recebe os leads).
NEXT_PUBLIC_CONTACT_EMAIL=contacto@flywheel.dev

# ── Redes sociais (rodapé) ─────────────────────────────────────────────────
NEXT_PUBLIC_SOCIAL_LINKEDIN=https://www.linkedin.com/
NEXT_PUBLIC_SOCIAL_GITHUB=https://github.com/

# ── Voucher do quiz de diagnóstico (exposto no client) ─────────────────────
NEXT_PUBLIC_QUIZ_VOUCHER_CODE=DIAGNOSTICO10
NEXT_PUBLIC_QUIZ_VOUCHER_PT="10% de desconto no seu primeiro projeto"
NEXT_PUBLIC_QUIZ_VOUCHER_EN="10% off your first project"
